# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/infopath_banking?schema=public
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/infopath_banking_shadow?schema=public

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-required
JWT_EXPIRES_IN_SECONDS=86400

# Frontend URL for CORS
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Billing Configuration
PREMIUM_MONTHLY_PRICE=299
